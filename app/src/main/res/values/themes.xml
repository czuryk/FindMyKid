<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.FindMyKid" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/accent_blue</item>
        <item name="colorPrimaryVariant">@color/neon_blue</item>
        <item name="colorOnPrimary">@color/text_white</item>
        
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/neon_cyan</item>
        <item name="colorSecondaryVariant">@color/neon_cyan</item>
        <item name="colorOnSecondary">@color/text_white</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/bg_darker</item>
        <item name="android:windowLightStatusBar">false</item>
        
        <!-- Background colors -->
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/text_white</item>
        
        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/text_white</item>
        <item name="android:textColorSecondary">@color/text_gray</item>
    </style>
</resources>
